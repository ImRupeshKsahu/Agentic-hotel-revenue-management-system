                     },
                     {
                         "id":  "t_mp_title",
                         "type":  "text",
                         "x":  36,
                         "y":  1486,
                         "width":  660,
                         "height":  34,
                         "angle":  0,
                         "strokeColor":  "#7f1d1d",
                         "backgroundColor":  "transparent",
