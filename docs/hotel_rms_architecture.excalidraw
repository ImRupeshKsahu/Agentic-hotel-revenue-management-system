                     {
                         "id":  "t_pms_body",
                         "type":  "text",
                         "x":  42,
                         "y":  948,
                         "width":  660,
                         "height":  300,
                         "angle":  0,
                         "strokeColor":  "#1e1e1e",
                         "backgroundColor":  "transparent",
                         "fillStyle":  "solid",
                         "strokeWidth":  1,
                         "strokeStyle":  "solid",
                         "roughness":  1,
                         "opacity":  100,
                         "groupIds":  [

                                      ],
                         "frameId":  null,
                         "roundness":  null,
                         "seed":  203,
                         "version":  1,
                         "versionNonce":  203,
                         "isDeleted":  false,
                         "boundElements":  null,
                         "updated":  1,
                         "link":  null,
                         "locked":  false,
                         "text":  "Main flow:\n1. Raw hotel bookings are normalized.\n2. Room nights are unrolled into daily hotel demand.\n3. Live PMS ledger is seeded for the demo horizon.\n4. Cancellation probabilities estimate likely retained rooms.\n5. OTB snapshot produces booked rooms, adjusted OTB, OTB ADR, and pace.\n6. Live market state JSON feeds the app and pricing engine.\n\nKey files:\n- src/pms_core/data_pipeline.py\n- src/pms_core/live_ledger.py\n- src/pms_core/snapshot.py\n- src/pricing_core/cancellation.py\n- data/live_market_state.json",
                         "fontSize":  17,
                         "fontFamily":  1,
                         "textAlign":  "left",
                         "verticalAlign":  "top",
                         "containerId":  null,
                         "originalText":  "Main flow:\n1. Raw hotel bookings are normalized.\n2. Room nights are unrolled into daily hotel demand.\n3. Live PMS ledger is seeded for the demo horizon.\n4. Cancellation probabilities estimate likely retained rooms.\n5. OTB snapshot produces booked rooms, adjusted OTB, OTB ADR, and pace.\n6. Live market state JSON feeds the app and pricing engine.\n\nKey files:\n- src/pms_core/data_pipeline.py\n- src/pms_core/live_ledger.py\n- src/pms_core/snapshot.py\n- src/pricing_core/cancellation.py\n- data/live_market_state.json",
