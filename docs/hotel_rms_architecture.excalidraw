                         "updated":  1,
                         "link":  null,
                         "locked":  false,
                         "text":  "Market Feed And Explainable Pricing",
                         "fontSize":  26,
                         "fontFamily":  1,
                         "textAlign":  "left",
                         "verticalAlign":  "top",
                         "containerId":  null,
                         "originalText":  "Market Feed And Explainable Pricing",
                         "lineHeight":  1.25,
                         "baseline":  28
                     },
                     {
                         "id":  "t_mp_body",
                         "type":  "text",
                         "x":  42,
                         "y":  1548,
                         "width":  665,
                         "height":  342,
                         "angle":  0,
                         "strokeColor":  "#1e1e1e",
                         "backgroundColor":  "transparent",
                         "fillStyle":  "solid",
                         "strokeWidth":  1,
                         "strokeStyle":  "solid",
                         "roughness":  1,
                         "opacity":  100,
                         "groupIds":  [

                                      ],
                         "frameId":  null,
                         "roundness":  null,
                         "seed":  403,
                         "version":  1,
                         "versionNonce":  403,
                         "isDeleted":  false,
                         "boundElements":  null,
                         "updated":  1,
                         "link":  null,
                         "locked":  false,
                         "text":  "Market feed:\n- Simulates competitor low / median / high rates.\n- Tags source quality and market regime.\n- Supports Scenario Lab market override.\n\nPricing engine:\n1. Combines forecast occupancy, OTB, pace, and comp-set context.\n2. Builds dynamic base / floor / ceiling from recent ADR and market context.\n3. Applies manual demand shock and approved local-intel shock.\n4. Tests candidate ADRs for expected occupancy and revenue.\n5. Applies guardrails: bounds, parity, sold-out behavior, manual review flags.\n6. Returns final ADR, price path, decision context, and audit rows.\n\nKey files:\n- src/market_core/feed.py\n- src/pricing_core/engine.py\n- src/copilot_core/pricing_agent.py",
                         "fontSize":  17,
                         "fontFamily":  1,
                         "textAlign":  "left",
                         "verticalAlign":  "top",
                         "containerId":  null,
                         "originalText":  "Market feed:\n- Simulates competitor low / median / high rates.\n- Tags source quality and market regime.\n- Supports Scenario Lab market override.\n\nPricing engine:\n1. Combines forecast occupancy, OTB, pace, and comp-set context.\n2. Builds dynamic base / floor / ceiling from recent ADR and market context.\n3. Applies manual demand shock and approved local-intel shock.\n4. Tests candidate ADRs for expected occupancy and revenue.\n5. Applies guardrails: bounds, parity, sold-out behavior, manual review flags.\n6. Returns final ADR, price path, decision context, and audit rows.\n\nKey files:\n- src/market_core/feed.py\n- src/pricing_core/engine.py\n- src/copilot_core/pricing_agent.py",
                         "lineHeight":  1.25,
                         "baseline":  300
                     },
