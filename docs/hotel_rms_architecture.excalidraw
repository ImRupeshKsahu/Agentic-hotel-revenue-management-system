                     {
                         "id":  "t_forecast_body",
                         "type":  "text",
                         "x":  862,
                         "y":  948,
                         "width":  665,
                         "height":  318,
                         "angle":  0,
                         "strokeColor":  "#1e1e1e",
                         "backgroundColor":  "transparent",
                         "fillStyle":  "solid",
                         "strokeWidth":  1,
                         "strokeStyle":  "solid",
                         "roughness":  1,
                         "opacity":  100,
                         "groupIds":  [

                                      ],
                         "frameId":  null,
                         "roundness":  null,
                         "seed":  303,
                         "version":  1,
                         "versionNonce":  303,
                         "isDeleted":  false,
                         "boundElements":  null,
                         "updated":  1,
                         "link":  null,
                         "locked":  false,
                         "text":  "Main flow:\n1. Forecast workflow refreshes daily data.\n2. Feature engineering builds lags, rolling stats, trend, calendar, and operational signals.\n3. Boruta keeps one selected ML feature profile plus force-kept baseline spine.\n4. One-time tuning saves reusable model parameters.\n5. Backtest mode runs model competition and audit folds.\n6. Forecast mode reuses champion + tuning artifacts for the daily horizon.\n\nKey files / artifacts:\n- src/workflows/demand_forecast.py\n- src/forecasting_core/engine.py\n- src/forecasting_core/legacy.py\n- data/forecast_champion.json\n- data/demand_forecast_output.csv\n- data/model_comparison_metrics.csv",
                         "fontSize":  17,
                         "fontFamily":  1,
                         "textAlign":  "left",
                         "verticalAlign":  "top",
                         "containerId":  null,
                         "originalText":  "Main flow:\n1. Forecast workflow refreshes daily data.\n2. Feature engineering builds lags, rolling stats, trend, calendar, and operational signals.\n3. Boruta keeps one selected ML feature profile plus force-kept baseline spine.\n4. One-time tuning saves reusable model parameters.\n5. Backtest mode runs model competition and audit folds.\n6. Forecast mode reuses champion + tuning artifacts for the daily horizon.\n\nKey files / artifacts:\n- src/workflows/demand_forecast.py\n- src/forecasting_core/engine.py\n- src/forecasting_core/legacy.py\n- data/forecast_champion.json\n- data/demand_forecast_output.csv\n- data/model_comparison_metrics.csv",
                         "lineHeight":  1.25,
                         "baseline":  280
